    },
    {
      "id": "mobile4",
      "name": "Mobile 4 - Compound Motion",
      "type": "custom",
      "transformId": "mobile4_horizontal",
      "subsystems": {
        "horizontalControl": {
          "minPosition": -1.0472,
          "maxPosition": 1.0472,
          "reinforcementPosition": 0,
          "tolerance": 0.05,
          "frameRate": 60,
          "maxVelocity": 0.6,
          "maxAcceleration": 0.4,
          "maxJerk": 0.15
        }
      }
