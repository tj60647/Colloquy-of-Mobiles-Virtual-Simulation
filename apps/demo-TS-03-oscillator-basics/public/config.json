      "parent": "mobile3_base",
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile4_base",
      "name": "Mobile 4 Base",
      "parent": "root",
      "position": { "x": 150, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile4_horizontal",
      "name": "Mobile 4 Horizontal (Parent)",
      "parent": "mobile4_base",
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile4_child",
