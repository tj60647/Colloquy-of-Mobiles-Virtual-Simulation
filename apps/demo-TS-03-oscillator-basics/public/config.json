  "mobiles": [
    {
      "id": "mobile1",
      "name": "Mobile 1 - Slow Sine",
      "type": "custom",
      "transformId": "mobile1_horizontal",
      "subsystems": {
        "horizontalControl": {
          "minPosition": -1.5708,
          "maxPosition": 1.5708,
          "reinforcementPosition": 0,
          "tolerance": 0.05,
          "frameRate": 60,
          "maxVelocity": 0.5,
          "maxAcceleration": 0.3,
          "maxJerk": 0.1
        }
      }
    },
    {
      "id": "mobile2",
      "name": "Mobile 2 - Fast Sine",
      "type": "custom",
      "transformId": "mobile2_horizontal",
      "subsystems": {
        "horizontalControl": {
          "minPosition": -3.14159,
          "maxPosition": 3.14159,
          "reinforcementPosition": 0,
          "tolerance": 0.05,
          "frameRate": 60,
          "maxVelocity": 1.5,
          "maxAcceleration": 1.0,
          "maxJerk": 0.5
        }
      }
    },
    {
      "id": "mobile3",
