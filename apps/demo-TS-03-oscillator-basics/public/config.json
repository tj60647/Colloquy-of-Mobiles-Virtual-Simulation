{
  "$schema": "../../SimulationConfigurationFiles/simulation-config-v2.schema.json",
  "version": "2.0",
  "name": "Oscillator Basics Demo",
  "description": "Demonstrates oscillator-driven animation with different motion profiles",
  
  "coordinateSystems": [
    {
      "id": "root",
      "name": "Root",
      "parent": null,
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile1_base",
      "name": "Mobile 1 Base",
