      "position": { "x": -150, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile1_horizontal",
      "name": "Mobile 1 Horizontal",
      "parent": "mobile1_base",
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile2_base",
      "name": "Mobile 2 Base",
      "parent": "root",
      "position": { "x": -50, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile2_horizontal",
      "name": "Mobile 2 Horizontal",
      "parent": "mobile2_base",
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
    },
    {
      "id": "mobile3_base",
      "name": "Mobile 3 Base",
      "parent": "root",
      "position": { "x": 50, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 }
