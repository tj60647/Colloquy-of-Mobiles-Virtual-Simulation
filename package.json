{
  "name": "colloquy-of-mobiles",
  "version": "2.0.0",
  "description": "Virtual simulation of Gordon Pask's Colloquy of Mobiles - TypeScript implementation with THREE.js visualization",
  "scripts": {
    "dev:gallery": "npm run build:demos && npx serve dist -p 3000",
    "dev:cleanup": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-dev-servers.ps1",
    "build": "tsc",
    "build:demos": "node scripts/build-all-demos.mjs",
    "deploy": "npm run build:demos && vercel deploy --prod",
    "type-check": "tsc --noEmit",
    "watch": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "three": "^0.168.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "author": "Your Name",
  "license": "MIT"
}
