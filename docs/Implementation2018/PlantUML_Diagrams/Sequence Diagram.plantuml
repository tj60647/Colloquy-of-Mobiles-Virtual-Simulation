@startuml
actor Agent
participant Environment

Agent -> Agent : Drive increments continuously
Agent -> Agent : Drive > Threshold?
alt Drive > Threshold
    Agent -> Environment : Find Partner Request
    Environment -> Agent : Response (Partner Found/Not Found)
    alt Partner Found
        Agent -> Environment : Engage Partner
        Environment -> Agent : Response (Successful/Unsuccessful)
        alt Successful Exchange
            Agent -> Agent : Drive decrements
            Agent -> Agent : Drive < Threshold?
            alt Drive < Threshold
                Agent -> Agent : Satisfied
            else Drive >= Threshold
                Agent -> Environment : Continue Engaging
            end
        else Unsuccessful Exchange
            Agent -> Agent : Resume Searching
        end
    else No Partner Found
        Agent -> Agent : Continue Searching
    end
else Drive <= Threshold
    Agent -> Agent : Remain Satisfied
end
@enduml