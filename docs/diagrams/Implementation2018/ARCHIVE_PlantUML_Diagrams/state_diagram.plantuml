<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <!-- Satisfied and Doing Nothing -->
  <rect x="50" y="50" width="200" height="100" rx="10" ry="10" style="fill:lightblue;stroke:black;stroke-width:2"/>
  <text x="70" y="110" font-family="Verdana" font-size="12" fill="black">Satisfied and Doing Nothing</text>

  <!-- Unsatisfied and Searching for a Partner -->
  <rect x="300" y="50" width="200" height="100" rx="10" ry="10" style="fill:lightcoral;stroke:black;stroke-width:2"/>
  <text x="320" y="110" font-family="Verdana" font-size="12" fill="black">Unsatisfied and Searching for a Partner</text>

  <!-- Engaging with a Partner -->
  <rect x="550" y="250" width="200" height="100" rx="10" ry="10" style="fill:lightgreen;stroke:black;stroke-width:2"/>
  <text x="570" y="310" font-family="Verdana" font-size="12" fill="black">Engaging with a Partner</text>

  <!-- Arrows and Text -->
  <!-- From Satisfied to Unsatisfied -->
  <line x1="250" y1="100" x2="300" y2="100" style="stroke:black;stroke-width:2"/>
  <polygon points="290,95 300,100 290,105" style="fill:black"/>
  <text x="220" y="90" font-family="Verdana" font-size="12" fill="black">Drive greater than Lower Bound</text>

  <!-- From Unsatisfied to Engaging -->
  <line x1="400" y1="150" x2="400" y2="250" style="stroke:black;stroke-width:2"/>
  <polygon points="395,240 400,250 405,240" style="fill:black"/>
  <text x="410" y="200" font-family="Verdana" font-size="12" fill="black">Partner Found</text>

  <!-- From Engaging to Satisfied -->
  <line x1="550" y1="300" x2="400" y2="300" style="stroke:black;stroke-width:2"/>
  <line x1="400" y1="300" x2="400" y2="100" style="stroke:black;stroke-width:2"/>
  <polygon points="395,110 400,100 405,110" style="fill:black"/>
  <text x="420" y="290" font-family="Verdana" font-size="12" fill="black">Drive less than Lower Bound</text>

  <!-- From Engaging to Unsatisfied -->
  <line x1="650" y1="250" x2="650" y2="150" style="stroke:black;stroke-width:2"/>
  <line x1="650" y1="150" x2="300" y2="150" style="stroke:black;stroke-width:2"/>
  <polygon points="310,145 300,150 310,155" style="fill:black"/>
  <text x="510" y="140" font-family="Verdana" font-size="12" fill="black">Exchange Continues</text>
</svg>