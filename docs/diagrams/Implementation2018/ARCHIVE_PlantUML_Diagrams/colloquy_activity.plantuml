@startuml
start
:Drive increments continuously;
if (Drive <= Threshold) then (yes)
    :Satisfied;
else (no)
    :Unsatisfied;
    repeat
        :Searching;
        :Drive increments continuously;
        if (Partner Found?) then (yes)
            :Engage Partner;
            if (Successful Exchange?) then (yes)
                :Drive decrements;
                if (Drive < Threshold) then (yes)
                    :Satisfied;
                else (no)
                    :Continue Engaging;
                    :Engage Partner;
                endif
            else (no)
                :Resume Searching;
            endif
        else (no)
            :Continue Searching;
        endif
    repeat while (Drive > Threshold)
endif
stop
@enduml