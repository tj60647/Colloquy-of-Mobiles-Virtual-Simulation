@startuml
[*] --> Idle

state Idle {
  [*] --> WaitingForLogin
  WaitingForLogin -> LoggedIn: login()
}

state LoggedIn {
  [*] --> WaitingForRequest
  WaitingForRequest -> ProcessingRequest: requestData()
  ProcessingRequest -> WaitingForRequest: sendData()
  WaitingForRequest -> LoggedOut: logout()
}

LoggedIn --> Idle: logout()
@enduml