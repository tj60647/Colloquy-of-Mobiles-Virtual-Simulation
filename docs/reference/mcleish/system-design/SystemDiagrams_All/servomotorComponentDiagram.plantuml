@startuml
' Filename: servomotorComponentDiagram.plantuml
' Diagram Type: Component Diagram
'
' Rewritten 2026-07-18. Previously a byte-for-byte duplicate of componentDiagram.plantuml
' (the physical armature hierarchy — see that file). This version instead shows the CURRENT
' oscillator -> servo actuation path: how a unit's VIRTUAL Servomotor Oscillator drives an
' OPTIONAL physical servo via the /actuator bridge. Grounded in the live app:
' src/simulation/oscillator-controller-agent.ts, oscillator-step.ts, and the /actuator client
' (docs/infrastructure/ACTUATOR_PAGE.md, docs/infrastructure/PHYGITAL_AUDIT_2026-07-17.md).

skinparam componentStyle rectangle
skinparam defaultTextAlignment center
skinparam component {
  BackgroundColor<<actuator>> #fff274
  BackgroundColor<<hardware>> #cfe8ff
}

package "Simulation Server (authoritative)" {
  component "Behavioral engine\n(state machines + drive)" as Engine
  component "Oscillator Controller Agent\n(oscillator-controller-agent.ts)" as OscAgent
  component "Servomotor Oscillator (virtual)\n(oscillator-step.ts:\nhold / release / engaging)" as VirtOsc <<actuator>>
  Engine --> OscAgent : requestMode (hold / release),\nreinforcementPosition
  OscAgent --> VirtOsc : per-tick target
  VirtOsc --> OscAgent : position / velocity / mode
}

OscAgent --> Wire : frame variables\n(position, velocity, mode)

component "WebSocket frame\n(keyframe + delta)" as Wire

Wire --> Actuator : subscribe (viewer-tier)

package "/actuator client (phygital bridge)" {
  component "Actuator page\n(maps oscillator stream -> servo goal;\nsafety limits, HOLD-on-stale)" as Actuator
}

Actuator --> DevServo : virtual dev servo (default)
Actuator --> ESP32 : ESP32 serial bridge (460800 baud)
Actuator --> Dxl : Dynamixel (Protocol 2.0 / 1.0, byte-exact)
Actuator --> BLE : BLE (experimental)

component "Virtual dev servo" as DevServo <<actuator>>
component "ESP32 bridge" as ESP32 <<hardware>>
component "Dynamixel servo" as Dxl <<hardware>>
component "BLE servo" as BLE <<hardware>>

note bottom of Actuator
  Mappings always load DISABLED and must be explicitly enabled.
  On a stale stream the bridge HOLDs the last safe position.
end note

@enduml
